# 模型配置（兼容 OpenAI / DeepSeek / 智谱 GLM / Qwen 等）
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 对话模型（智谱免费模型：glm-4-flash）
LLM_MODEL=glm-4-flash

# Embedding 模型（代码中硬编码为 BAAI/bge-small-zh-v1.5，此变量仅用于展示）
# 如需更换，请修改 knowledge_qa/vector_store.py 中的 model_name 参数
# EMBEDDING_MODEL=embedding-2

# 相似度阈值（0.0~1.0，低于此值的检索结果将被过滤，默认 0.5）
SIMILARITY_THRESHOLD=0.5
